{
  "functions": {
    "backend/src/app.js": {
      "runtime": "@vercel/node",
      "includeFiles": "backend/prisma/**"
    }
  },
  "rewrites": [
    {
      "source": "/api",
      "destination": "/backend/src/app.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/backend/src/app.js"
    }
  ]
}
